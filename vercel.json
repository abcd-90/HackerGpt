{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "hackerGPT/**/*", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/lws-control-hub", "destination": "/api/lws-control-hub.js" },
    { "source": "/api/chat", "destination": "/api/chat.js" },
    { "source": "/api/logs", "destination": "/api/logs.js" },
    { "source": "/api/clear-logs", "destination": "/api/clear-logs.js" },
    { "source": "/", "destination": "/hackerGPT/index.html" },
    { "source": "/hackerGPT", "destination": "/hackerGPT/index.html" }
  ]
}
